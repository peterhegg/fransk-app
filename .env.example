# Kopier denne filen til .env og fyll inn verdiene
VITE_PROXY_URL=https://fransk-proxy.DITTBRUKERNAVN.workers.dev
# Generer et tilfeldig token, f.eks.: openssl rand -hex 32
# Samme verdi må settes som Cloudflare Worker secret: wrangler secret put CLIENT_TOKEN
# Og som GitHub Actions secret: VITE_APP_TOKEN
VITE_APP_TOKEN=ditt-hemmelige-token-her
